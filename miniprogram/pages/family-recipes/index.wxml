<view class="page-shell">
  <view class="page-heading">
    <text class="eyebrow">家里的味道</text>
    <text class="page-title">家庭菜谱</text>
    <text class="page-copy">一起留下常做的家常菜</text>
  </view>

  <view class="list-toolbar">
    <view class="tab-rail" role="tablist" aria-label="家庭菜谱分类">
      <button
        class="tab-button {{activeTab === 'PUBLISHED' ? 'tab-button--active' : ''}}"
        role="tab"
        aria-selected="{{activeTab === 'PUBLISHED'}}"
        data-tab="PUBLISHED"
        bindtap="onSelectTab"
      >已发布</button>
      <button
        class="tab-button {{activeTab === 'DRAFT' ? 'tab-button--active' : ''}}"
        role="tab"
        aria-selected="{{activeTab === 'DRAFT'}}"
        data-tab="DRAFT"
        bindtap="onSelectTab"
      >我的草稿</button>
      <button
        class="tab-button {{activeTab === 'ARCHIVED' ? 'tab-button--active' : ''}}"
        role="tab"
        aria-selected="{{activeTab === 'ARCHIVED'}}"
        data-tab="ARCHIVED"
        bindtap="onSelectTab"
      >已归档</button>
    </view>

    <button
      class="create-button {{creating ? 'create-button--disabled' : ''}}"
      loading="{{creating}}"
      disabled="{{creating}}"
      aria-label="{{creating ? '正在新建菜谱' : '新建菜谱'}}"
      bindtap="onCreateDraft"
    >{{creating ? '新建中' : '新建菜谱'}}</button>
  </view>

  <text wx:if="{{refreshing}}" class="refreshing-copy">正在更新菜谱…</text>

  <view wx:if="{{errorMessage}}" class="error-state" role="alert">
    <text class="error-copy">{{errorMessage}}</text>
    <button class="retry-button" bindtap="onRetry">重新加载</button>
  </view>

  <view wx:if="{{loading}}" class="loading-state">正在整理家庭菜谱…</view>

  <view wx:elif="{{items.length}}" class="recipe-list">
    <button
      wx:for="{{items}}"
      wx:key="id"
      class="recipe-row {{activeTab === 'ARCHIVED' ? 'recipe-row--archived' : ''}}"
      data-id="{{item.id}}"
      aria-label="打开{{item.name || '未命名菜谱'}}"
      bindtap="onOpenRecipe"
    >
      <image
        wx:if="{{item.imageUrl}}"
        class="recipe-image"
        src="{{item.imageUrl}}"
        mode="aspectFill"
        aria-label="{{item.name || '未命名菜谱'}}图片"
      />
      <view wx:else class="recipe-image recipe-image--empty" role="img" aria-label="暂无菜谱图片">
        <text class="image-empty-copy">暂无图片</text>
      </view>

      <view class="recipe-copy">
        <text class="recipe-name">{{item.name || '未命名菜谱'}}</text>

        <view wx:if="{{activeTab === 'PUBLISHED'}}" class="recipe-meta">
          <text>{{item.creatorName || '家庭成员'}}创建</text>
          <text wx:if="{{item.lastModifiedByName}}"> · {{item.lastModifiedByName}}修改</text>
        </view>

        <view wx:elif="{{activeTab === 'DRAFT'}}" class="recipe-meta">
          <text>编辑进度</text>
          <text wx:if="{{item.completedStep === 'BASIC'}}"> · 基本信息</text>
          <text wx:elif="{{item.completedStep === 'INGREDIENTS'}}"> · 食材</text>
          <text wx:elif="{{item.completedStep === 'METHOD'}}"> · 做法</text>
          <text wx:elif="{{item.completedStep === 'IMAGE'}}"> · 图片</text>
          <text wx:else> · 预览</text>
        </view>

        <view wx:else class="recipe-meta">
          <text>已归档菜谱</text>
          <text wx:if="{{item.lastModifiedByName}}"> · {{item.lastModifiedByName}}最后修改</text>
        </view>

        <view class="recipe-facts">
          <text wx:if="{{item.servings}}">{{item.servings}} 人份</text>
          <text wx:if="{{item.estimatedMinutes}}"> · {{item.estimatedMinutes}} 分钟</text>
        </view>
      </view>

      <text class="row-action">查看</text>
    </button>
  </view>

  <view wx:elif="{{!errorMessage}}" class="empty-state">
    <text wx:if="{{activeTab === 'PUBLISHED'}}" class="empty-title">还没有家庭菜谱，先从一道家常菜开始</text>
    <text wx:elif="{{activeTab === 'DRAFT'}}" class="empty-title">没有未完成的草稿</text>
    <text wx:else class="empty-title">归档后的菜谱会留在这里</text>
  </view>

  <text class="privacy-copy">家庭菜谱只对你们两个人可见</text>
</view>
