.page-shell { box-sizing: border-box; min-height: 100vh; padding: 44rpx 30rpx calc(290rpx + env(safe-area-inset-bottom)); }
.page-heading { padding: 0 8rpx 34rpx; }
.eyebrow, .page-title, .page-copy, .recipe-name, .recipe-meta { display: block; }
.eyebrow { color: #7b823b; font-size: 24rpx; font-weight: 650; letter-spacing: 3rpx; }
.page-title { margin-top: 16rpx; font-size: 46rpx; font-weight: 750; }
.page-copy { margin-top: 14rpx; color: #77736b; font-size: 25rpx; }
.conflict-banner, .error-banner { display: flex; align-items: center; gap: 12rpx; margin-bottom: 26rpx; padding: 20rpx 22rpx; border: 1rpx solid #dfd8b9; border-radius: 18rpx; background: #fbfaf0; color: #6e703d; font-size: 23rpx; line-height: 1.5; }
.banner-icon { width: 36rpx; height: 36rpx; flex: 0 0 auto; }
.error-banner { border-color: #e7c8b8; background: #fff5ef; color: #aa4525; }
.completed-banner { margin-bottom: 26rpx; padding: 20rpx 22rpx; border: 1rpx solid #ded8c4; border-radius: 18rpx; background: #fbfaf2; color: #6e703d; font-size: 23rpx; text-align: center; }
.status-state { padding: 180rpx 0; color: #77736b; text-align: center; font-size: 27rpx; }
.recipe-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22rpx; }
.recipe-card { position: relative; overflow: hidden; border: 2rpx solid #eadfce; border-radius: 24rpx; background: #fffdf9; box-shadow: 0 10rpx 28rpx rgba(72, 55, 29, 0.05); }
.recipe-card--selected { border-color: #7b823b; box-shadow: 0 0 0 4rpx rgba(123, 130, 59, 0.12); }
.recipe-image { display: block; width: 100%; height: 286rpx; background: #eee5d8; }
.selected-mark { position: absolute; top: 14rpx; right: 14rpx; display: flex; width: 48rpx; height: 48rpx; align-items: center; justify-content: center; border: 4rpx solid #fff; border-radius: 50%; background: #7b823b; }
.check-icon { width: 30rpx; height: 30rpx; }
.recipe-body { padding: 19rpx 18rpx 23rpx; }
.recipe-name { font-size: 29rpx; font-weight: 700; }
.recipe-meta { margin-top: 8rpx; color: #8a857b; font-size: 21rpx; }
.save-area { position: fixed; right: 0; bottom: calc(100rpx + env(safe-area-inset-bottom)); left: 0; z-index: 15; padding: 20rpx 30rpx; border-top: 1rpx solid #eadfce; background: rgba(255, 250, 243, 0.97); }
.save-button { display: flex; min-height: 94rpx; align-items: center; justify-content: center; border-radius: 22rpx; background: #ca5325; color: #fff; font-size: 30rpx; font-weight: 700; line-height: 94rpx; }
