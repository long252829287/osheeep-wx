.detail-page { box-sizing: border-box; width: 100%; min-height: 100vh; overflow-x: hidden; padding: 36rpx 32rpx calc(154rpx + env(safe-area-inset-bottom)); }
.status-state { padding: 220rpx 0; color: #77736b; text-align: center; font-size: 27rpx; }
.status-state--error { color: #bd472b; }
.success-banner { display: flex; align-items: center; gap: 20rpx; padding: 28rpx 30rpx; border: 1rpx solid #dcd9bd; border-radius: 24rpx; background: #fbfaef; }
.success-icon { display: flex; width: 62rpx; height: 62rpx; align-items: center; justify-content: center; border-radius: 50%; background: #7b823b; flex: 0 0 auto; }
.success-icon-image { width: 38rpx; height: 38rpx; }
.success-title, .success-copy, .detail-title, .detail-copy, .dish-name, .snapshot-heading, .method-name, .method-style, .step-instruction, .ingredient-name, .ingredient-amount, .record-note { display: block; }
.success-title { color: #73783c; font-size: 31rpx; font-weight: 730; }
.success-copy { margin-top: 7rpx; color: #77736b; font-size: 23rpx; }
.record-panel { box-sizing: border-box; width: 100%; margin-top: 28rpx; padding: 38rpx 28rpx 34rpx; border: 1rpx solid #e1d7c9; border-radius: 28rpx; background: #fffdf9; }
.detail-heading { display: flex; align-items: center; gap: 18rpx; }
.heading-icon { width: 48rpx; height: 48rpx; flex: 0 0 auto; }
.detail-title { font-size: 36rpx; font-weight: 750; }
.detail-copy { margin-top: 8rpx; color: #77736b; font-size: 24rpx; }
.dish-list { display: flex; min-width: 0; gap: 24rpx; margin-top: 34rpx; flex-direction: column; }
.dish-card { box-sizing: border-box; min-width: 0; overflow: hidden; border: 1rpx solid #e5dccd; border-radius: 24rpx; background: #fffdf9; }
.dish-card--legacy { display: grid; grid-template-columns: 156rpx minmax(0, 1fr); align-items: center; gap: 18rpx; padding: 16rpx; }
.dish-image { display: block; width: 100%; height: 300rpx; background: #f1ece2; }
.dish-card--legacy .dish-image { width: 156rpx; height: 132rpx; border-radius: 18rpx; }
.dish-image--placeholder { display: flex; align-items: center; justify-content: center; background: #f5f1e8; }
.dish-placeholder-icon { width: 84rpx; height: 84rpx; opacity: 0.78; }
.dish-card--legacy .dish-placeholder-icon { width: 62rpx; height: 62rpx; }
.dish-content { min-width: 0; padding: 24rpx; }
.dish-card--legacy .dish-content { padding: 0; }
.dish-title-line { display: flex; min-width: 0; align-items: flex-start; gap: 12rpx; flex-wrap: wrap; }
.dish-name { min-width: 0; color: #302e29; font-size: 29rpx; font-weight: 710; line-height: 1.4; word-break: break-all; flex: 1 1 200rpx; }
.recipe-scope-label { display: inline-flex; min-height: 34rpx; align-items: center; padding: 2rpx 10rpx; border-radius: 10rpx; background: #f3f4e8; color: #6d713a; font-size: 20rpx; font-weight: 650; line-height: 30rpx; white-space: nowrap; flex: 0 0 auto; }
.dish-meta-line { display: flex; min-width: 0; align-items: center; gap: 12rpx; margin-top: 10rpx; color: #77736b; font-size: 22rpx; line-height: 1.4; flex-wrap: wrap; }
.consensus-label { padding: 4rpx 10rpx; border-radius: 12rpx; background: #f3f4e8; color: #6d713a; font-size: 19rpx; font-weight: 650; white-space: nowrap; }
.snapshot-section { margin-top: 22rpx; padding-top: 20rpx; border-top: 1rpx solid #e8dfd2; }
.snapshot-heading { color: #b94c26; font-size: 24rpx; font-weight: 720; }
.method-summary { display: flex; min-width: 0; align-items: center; gap: 12rpx; margin-top: 12rpx; flex-wrap: wrap; }
.method-name { min-width: 0; color: #3f3c36; font-size: 27rpx; font-weight: 700; word-break: break-all; flex: 1 1 240rpx; }
.method-style { box-sizing: border-box; min-width: 0; max-width: 100%; padding: 4rpx 11rpx; border-radius: 12rpx; background: #f3f4e8; color: #6d713a; font-size: 20rpx; line-height: 28rpx; white-space: normal; word-break: break-all; flex: 0 1 auto; }
.method-steps { display: flex; gap: 14rpx; margin-top: 18rpx; flex-direction: column; }
.method-step { display: grid; min-width: 0; grid-template-columns: 38rpx minmax(0, 1fr); align-items: flex-start; gap: 12rpx; }
.step-index { display: flex; width: 38rpx; height: 38rpx; align-items: center; justify-content: center; border-radius: 50%; background: #596326; color: #fff; font-size: 19rpx; line-height: 38rpx; }
.step-instruction { min-width: 0; padding-top: 3rpx; color: #57534c; font-size: 23rpx; line-height: 1.55; word-break: break-all; }
.ingredient-list { margin-top: 10rpx; }
.ingredient-row { display: flex; min-width: 0; align-items: flex-start; justify-content: space-between; gap: 20rpx; padding: 12rpx 0; border-bottom: 1rpx solid #eee6da; flex-wrap: wrap; }
.ingredient-name { min-width: 0; color: #555149; font-size: 23rpx; line-height: 1.45; word-break: break-all; flex: 1 1 200rpx; }
.ingredient-amount { min-width: 0; max-width: 100%; color: #73783c; text-align: right; font-size: 23rpx; font-weight: 650; line-height: 1.45; white-space: normal; word-break: break-all; flex: 0 1 auto; }
.primary-button, .secondary-button { display: flex; min-height: 90rpx; align-items: center; justify-content: center; margin-top: 34rpx; border-radius: 20rpx; font-size: 29rpx; font-weight: 690; line-height: 90rpx; }
.primary-button { background: #ca5325; color: #fff; }
.secondary-button { margin-top: 18rpx; border: 2rpx solid #ca5325; background: transparent; color: #ca5325; }
.record-note { margin-top: 24rpx; color: #858078; text-align: center; font-size: 21rpx; }
