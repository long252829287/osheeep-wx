.tonight-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 96rpx 56rpx calc(48rpx + env(safe-area-inset-bottom));
  text-align: center;
}

.loading-state,
.error-state {
  padding-top: 240rpx;
  color: #77736b;
  font-size: 28rpx;
}

.error-state {
  color: #bd472b;
}

.eyebrow,
.title,
.copy,
.placeholder-label,
.placeholder-title,
.placeholder-copy {
  display: block;
}

.eyebrow {
  color: #747c38;
  font-size: 26rpx;
  font-weight: 650;
  letter-spacing: 3rpx;
}

.success-mark {
  margin-top: 70rpx;
}

.title {
  margin-top: 26rpx;
  font-size: 50rpx;
  font-weight: 750;
}

.copy {
  margin-top: 22rpx;
  color: #66635d;
  font-size: 29rpx;
  line-height: 1.55;
}

.placeholder-card {
  margin-top: 76rpx;
  padding: 54rpx 38rpx;
  border: 2rpx solid #ddd4bf;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.58);
}

.placeholder-label {
  color: #c84d20;
  font-size: 24rpx;
  font-weight: 700;
}

.placeholder-title {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.placeholder-copy {
  margin-top: 18rpx;
  color: #77736b;
  font-size: 26rpx;
  line-height: 1.55;
}

.primary-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-right: 0;
  margin-left: 0;
  padding: 0;
  min-height: 100rpx;
  margin-top: 54rpx;
  border-radius: 24rpx;
  background: #cb5527;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 650;
  line-height: 100rpx;
}
