<view class="detail-page">
  <view wx:if="{{loading}}" class="status-state">正在打开这顿晚饭…</view>
  <view wx:elif="{{errorMessage}}" class="status-state status-state--error">{{errorMessage}}</view>
  <block wx:elif="{{record}}">
    <view class="success-banner">
      <view class="success-icon"><image class="success-icon-image" src="/assets/icons/check-white.svg" /></view>
      <view>
        <text class="success-title">已生成做饭记录</text>
        <text class="success-copy">{{record.recordDate}} · 这顿饭已完成</text>
      </view>
    </view>

    <view class="record-panel">
      <view class="detail-heading">
        <image class="heading-icon" src="/assets/icons/clipboard-orange.svg" />
        <view>
          <text class="detail-title">今晚一起吃的晚饭</text>
          <text class="detail-copy">共 {{dishes.length}} 道菜</text>
        </view>
      </view>
      <view class="dish-list">
        <view wx:for="{{dishes}}" wx:key="recipeId" class="dish-card {{item.showSnapshotDetails ? 'dish-card--detailed' : 'dish-card--legacy'}}">
          <image wx:if="{{item.imagePath}}" class="dish-image" src="{{item.imagePath}}" mode="aspectFill" aria-role="img" aria-label="{{item.name}}菜品图片" />
          <view wx:else class="dish-image dish-image--placeholder" aria-role="img" aria-label="{{item.name}}，暂无菜品图片">
            <image class="dish-placeholder-icon" src="/assets/icons/bowl-muted.svg" mode="aspectFit" aria-hidden="true" />
          </view>
          <view class="dish-content">
            <view class="dish-title-line">
              <text class="dish-name">{{item.name}}</text>
              <text wx:if="{{item.scopeLabel}}" class="recipe-scope-label">{{item.scopeLabel}}</text>
            </view>
            <view class="dish-meta-line">
              <text>{{item.flavor}} · {{item.estimatedMinutes}} 分钟</text>
              <text wx:if="{{item.source === 'BOTH'}}" class="consensus-label">共同选择</text>
            </view>

            <block wx:if="{{item.showSnapshotDetails}}">
              <view wx:if="{{item.method}}" class="snapshot-section method-section">
                <text class="snapshot-heading">做法</text>
                <view class="method-summary">
                  <text class="method-name">{{item.method.name}}</text>
                  <text class="method-style">{{item.method.cookingStyle}}</text>
                </view>
                <view wx:if="{{item.method.steps.length}}" class="method-steps">
                  <view wx:for="{{item.method.steps}}" wx:for-item="step" wx:for-index="stepIndex" wx:key="sortOrder" class="method-step">
                    <text class="step-index">{{stepIndex + 1}}</text>
                    <text class="step-instruction">{{step.instruction}}</text>
                  </view>
                </view>
              </view>

              <view wx:if="{{item.ingredients.length}}" class="snapshot-section ingredient-section">
                <text class="snapshot-heading">食材</text>
                <view class="ingredient-list">
                  <view wx:for="{{item.ingredients}}" wx:for-item="ingredient" wx:key="sortOrder" class="ingredient-row">
                    <text class="ingredient-name">{{ingredient.name}}</text>
                    <text class="ingredient-amount">{{ingredient.amountLabel}}</text>
                  </view>
                </view>
              </view>
            </block>
          </view>
        </view>
      </view>
      <button class="primary-button" bindtap="onBackToTonight">回到今晚菜单</button>
      <button class="secondary-button" bindtap="onBackToRecords">返回做饭记录</button>
      <text class="record-note">菜谱后续修改不会影响这条记录</text>
    </view>
  </block>
</view>
<bottom-nav active="records" />
