<view class="page">
  <view class="brand" aria-label="今晚吃什么">今晚吃什么</view>

  <view class="hero">
    <view class="title">
      <text class="title-me">今晚吃什么，</text>
      <text class="title-together">一起决定</text>
    </view>
    <text class="subtitle">和 TA 分别选菜，自动合并成今晚菜单</text>
  </view>

  <view class="flow" aria-label="使用步骤">
    <view class="flow-item flow-item-me">
      <text class="flow-number">01</text>
      <text class="flow-title">我来选菜</text>
      <text class="flow-copy">选出我想吃的</text>
    </view>
    <view class="flow-item flow-item-together">
      <text class="flow-number">02</text>
      <text class="flow-title">自动合并</text>
      <text class="flow-copy">找到共同选择</text>
    </view>
    <view class="flow-item flow-item-partner">
      <text class="flow-number">03</text>
      <text class="flow-title">TA 也选择</text>
      <text class="flow-copy">一起确认菜单</text>
    </view>
  </view>

  <view class="footer">
    <text wx:if="{{errorMessage}}" class="error" role="alert">{{errorMessage}}</text>
    <button
      class="primary"
      loading="{{loading}}"
      disabled="{{loading}}"
      bindtap="onContinue"
    >微信登录并继续</button>
    <text class="privacy">登录即表示你已阅读并同意《用户协议》和《隐私保护指引》</text>
    <text class="permission-note">首次登录不会自动获取手机号或相册权限</text>
  </view>
</view>
