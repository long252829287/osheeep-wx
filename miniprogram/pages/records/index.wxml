<view class="page-shell">
  <view class="page-heading">
    <text class="eyebrow">一起吃过的晚饭</text>
    <text class="page-title">做饭记录</text>
    <text class="page-copy">每次完成的菜单都会留在这里</text>
  </view>

  <view wx:if="{{loading}}" class="status-state">正在读取记录…</view>
  <view wx:elif="{{errorMessage}}" class="status-state status-state--error">{{errorMessage}}</view>
  <view wx:elif="{{records.length === 0}}" class="empty-card">
    <text class="empty-title">还没有做饭记录</text>
    <text class="empty-copy">完成第一份今晚菜单后，这里就会留下回忆</text>
  </view>
  <view wx:else class="record-list">
    <view wx:for="{{records}}" wx:key="id" class="record-card" data-id="{{item.id}}" bindtap="onOpenRecord">
      <view>
        <text class="record-date">{{item.recordDate}}</text>
        <text class="record-meta">{{item.dishCount}} 道菜 · 已完成</text>
      </view>
      <text class="record-arrow">›</text>
    </view>
  </view>
</view>
<bottom-nav active="records" />
