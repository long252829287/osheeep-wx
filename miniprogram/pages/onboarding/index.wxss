.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 112rpx 40rpx calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.brand {
  text-align: center;
  font-size: 34rpx;
  font-weight: 650;
  letter-spacing: 4rpx;
}

.hero {
  margin-top: 112rpx;
  text-align: center;
}

.title {
  font-size: 54rpx;
  font-weight: 750;
  line-height: 1.32;
}

.title-me {
  color: #c95e2f;
}

.title-together {
  color: #6d773c;
}

.subtitle {
  display: block;
  margin-top: 26rpx;
  color: #65635d;
  font-size: 29rpx;
  line-height: 1.6;
}

.flow {
  display: flex;
  gap: 16rpx;
  margin-top: 100rpx;
}

.flow-item {
  flex: 1;
  min-width: 0;
  padding: 30rpx 16rpx;
  border: 1rpx solid rgba(40, 39, 34, 0.1);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
}

.flow-number,
.flow-title,
.flow-copy {
  display: block;
}

.flow-number {
  color: #c95e2f;
  font-size: 24rpx;
  font-weight: 700;
}

.flow-title {
  margin-top: 16rpx;
  font-size: 27rpx;
  font-weight: 650;
}

.flow-copy {
  margin-top: 10rpx;
  color: #77746c;
  font-size: 22rpx;
  line-height: 1.45;
}

.flow-item-together .flow-number {
  color: #6d773c;
}

.flow-item-partner .flow-number {
  color: #4e7fa8;
}

.footer {
  margin-top: auto;
  padding-top: 88rpx;
  text-align: center;
}

.primary {
  min-height: 104rpx;
  border-radius: 28rpx;
  background: #ce5928;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 650;
  line-height: 104rpx;
}

.primary[disabled] {
  background: #dba384;
  color: rgba(255, 255, 255, 0.9);
}

.error {
  display: block;
  margin-bottom: 20rpx;
  color: #b83b2f;
  font-size: 26rpx;
  line-height: 1.5;
}

.privacy,
.permission-note {
  display: block;
  color: #77746c;
  font-size: 23rpx;
  line-height: 1.6;
}

.privacy {
  margin-top: 28rpx;
}

.permission-note {
  margin-top: 8rpx;
  color: #97938a;
}
